{
    "global": {
        "plugins": ["custom_recos.decode_ecal", "custom_recos.decode_mem", "custom_recos.hodo_reco", "custom_recos.bcp_reco", "custom_plot_functions.drawTTgrid"],
        "spill_type": {
            "electrons": {
                "plot_list": "plotlists/plot_list_electrons.csv",
                "tree_name": "h4",
                "detector_list": ["ecal", "mcp", "hodo", "bcp", "digi_bcp_clock_reading"],
                "global_branches": ["time_rc"],
                "option": null
            },
            "pions": {
                "plot_list": "plotlists/plot_list_pions.csv",
                "tree_name": "h4",
                "detector_list": ["ecal", "digi_bcp_clock_reading", "scint_discr"],
                "global_branches": ["time_rc"],
                "option": null
            },
            "laser": {
                "plot_list": "plotlists/plot_list_laser.csv",
                "tree_name": "h4_laser",
                "detector_list": ["ecal", "mem"],
                "global_branches": ["time_rc"],
                "option": {
                    "ecal": {
                        "reco_conf": {
                            "do_central_region": false
                        }
                    }
                }
            }
        }
    },
    "detectors": {
        "ecal": {
            "generic_reco": {
                "waves_branch": "xtal_sample",
                "_comment": "null ch_map means all channels active, list is active chs, string is map filename",
                "ch_map": "maps/tb_map.csv",
                "chid_vars_list": ["n_bcp","tt","ch_in_tt","module"],
                "decode": "decode_ecal",
                "to_be_inverted": false,
                "waves_branch": "xtal_sample",
                "remove_last_n_samples": 0,
                "geo_needed": ["ieta", "iphi"],
                "apply_gain_ratios": "high_over_low_gain_ratio",
                "apply_intercalib": "intercalib_factor",
                "reco_conf": {
                    "signal_samples_pre_peak": 5,
                    "signal_samples_post_peak": 10,
                    "charge_zerosup_peak_threshold": 10,
                    "seed_charge_threshold": 50,
                    "do_tau": true,
                    "tau_descent_samples": 3,
                    "do_central_region": true,
                    "coords_2d_list": ["ieta", "iphi"],
                    "do_timing": true,
                    "timing_methods": ["lsfit"],
                    "spline_file": "templates/template.txt",
                    "sampling_rate": 0.16,
                    "save_mean_rms_all_samples": true,
                    "save_only_central_region_info": false,
                    "charge_to_peak_slope": 0.271,
                    "charge_to_peak_conversion": true,
                    "w0_centroid": 3.8,
                    "min_outer_over_seed_ratio": 0.2,
                    "central_region_width": 5
                }
            }
        },

        "mem": {
            "generic_reco":
            {
                "waves_branch": "xtal_sample",
                "_comment": "null ch_map means all channels active, list is active chs, string is map filename",
                "ch_map": "maps/tb_map.csv",
                "chid_vars_list": ["n_bcp","tt","ch_in_tt"],
                "decode": "decode_mem",
                "to_be_inverted": false,
                "geo_needed": ["ieta", "iphi"],
                "remove_last_n_samples": 0,
                "apply_gain_ratios": null,
                "apply_intercalib": null,
                "reco_conf": {
                    "signal_samples_pre_peak": 5,
                    "signal_samples_post_peak": 10,
                    "charge_zerosup_peak_threshold": 10,
                    "coords_2d_list": ["ieta", "iphi"],
                    "seed_charge_threshold": 50,
                    "sampling_rate": 0.08,
                    "save_mean_rms_all_samples": true
                }
            }
    	},

        "mcp": {
            "generic_reco":
            {
                "waves_branch": "dgtz_sample",
                "_comment": "null ch_map means all channels active, list is active chs, string is map filename",
                "ch_map": [1, 2],
                "decode": null,
                "to_be_inverted": true,
                "remove_last_n_samples": 50,
                "reco_conf": {
                    "signal_samples_pre_peak": 13,
                    "signal_samples_post_peak": 15,
                    "charge_zerosup_peak_threshold": 60,
                    "seed_charge_threshold": 0,
                    "do_timing": true,
                    "timing_methods": ["cf"],
                    "sampling_rate": 5,
                    "rise_samples_pre_peak": 12,
                    "rise_samples_post_peak": 4,
                    "rise_interp_left_samples": 3,
                    "rise_interp_right_samples": 3,
                    "cf": 0.2,
                    "interpolation_factor": 40
                }
            }
        },
        "digi_bcp_clock_reading": {
            "generic_reco":
            {
                "waves_branch": "dgtz_sample",
                "_comment": "null ch_map means all channels active, list is active chs, string is map filename",
                "ch_map": [0],
                "decode": null,
                "to_be_inverted": false,
                "generic_reco": true,
                "remove_last_n_samples": 993,
                "reco_conf": {
                    "signal_samples_pre_peak": 30,
                    "signal_samples_post_peak": 30,
                    "charge_zerosup_peak_threshold": 0,
                    "seed_charge_threshold": 0,
                    "do_timing": true,
                    "sampling_rate": 5,
                    "rise_samples_pre_peak": 30,
                    "rise_samples_post_peak": 30,
                    "rise_interp_left_samples": 1,
                    "rise_interp_right_samples": 2,
                    "timing_methods": ["fixed_thr"],
                    "timing_thr": 1100,
                    "timing_thr_tol": 200,
                    "interpolation_factor": 40,
                    "baseline_subtract": false
                }
             }
        },

      	"scint_discr": {
            "generic_reco":
            {
                "waves_branch": "dgtz_sample",
                "_comment": "null ch_map means all channels active, list is active chs, string is map filename",
                "ch_map": [1],
                "decode": null,
                "to_be_inverted": true,
                "remove_last_n_samples": 50,
                "reco_conf": {
                    "signal_samples_pre_peak": 20,
                    "signal_samples_post_peak": 20,
                    "charge_zerosup_peak_threshold": 0,
                    "seed_charge_threshold": 0,
                    "do_timing": true,
                    "sampling_rate": 5,
                    "rise_samples_pre_peak": 20,
                    "rise_samples_post_peak": 5,
                    "rise_interp_left_samples": 5,
                    "rise_interp_right_samples": 5,
                    "timing_methods": ["fixed_thr"],
                    "timing_thr": 1500,
                    "timing_thr_tol": 100,
                    "interpolation_factor": 40,
                    "raw_threshold_before_peak_finding": 1500
                }
            }
       	},

        "hodo": {
            "generic_reco": null,
            "custom_reco": "hodo"
        },

        "bcp": {
            "generic_reco": null,
            "custom_reco": "bcp"
        }
    }
}
